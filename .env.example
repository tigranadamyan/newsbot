# Telegram Bot (aiogram — sends pushes + digests)
BOT_TOKEN=your_bot_token_here

# RSS Source
MEDUZA_RSS_URL=https://meduza.io/rss/all

# Database
DATABASE_URL=sqlite+aiosqlite:///data/news.db

# LLM — required for AI filtering
# Provider: "openai" | "deepseek" | "ollama" | "none"
#   none = rule-based fallback (less accurate, no API key needed)
#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini
#OPENAI_API_KEY=sk-your-key-here

# DeepSeek (OpenAI-compatible, cheaper)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Ollama (if using local LLM)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# AI Filter Prompt — describe what news you want and don't want
FILTER_PROMPT=Меня интересуют: технологии, наука, значимые политические события, экономика. Не присылай: катастрофы, криминал, сплетни, спорт, развлекательные новости, погоду, курсы валют.

# Scheduler
FETCH_INTERVAL_SECONDS=60
MORNING_DIGEST_HOUR=9
EVENING_DIGEST_HOUR=20

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=0
